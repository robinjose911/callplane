{
  "name": "@callplane/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@callplane/contracts": "*",
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
