## Tier 1 — browser demo (no external accounts required)
NODE_ENV=development
PORT=4400
API_BASE_URL=http://localhost:4300
# Must match apps/api's CALLPLANE_API_KEY — the console calls the API server-side only,
# never from the browser (no CORS, no client-side key; NVA-proven pattern).
CALLPLANE_API_KEY=dev-local-only-change-me
# Any long random string works locally.
SESSION_SECRET=dev-local-only-change-me-32-chars-min
CONSOLE_USER=admin
CONSOLE_PASSWORD=dev-local-only-change-me

## Tier 2 / Tier 3
# Nothing console-specific — provider and telephony config are DB rows edited
# in the console itself (D6), not env vars.

## Tier 4 — optional ops
# LOG_LEVEL=debug
# LOG_PRETTY=true
