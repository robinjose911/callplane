## Tier 1 — browser demo (no external accounts required)
NODE_ENV=development
SERVICE_NAME=callplane-worker
WORKER_HEALTH_PORT=4301
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/callplane?schema=callplane
REDIS_URL=redis://localhost:6379
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
PROVIDER_STUB_MODE=true
SIP_STUB_MODE=true
RECORDING_MODE=stub
# Must match apps/api/.env's RECORDINGS_DIR exactly — see that file's comment for why.
RECORDINGS_DIR=/tmp/callplane-recordings

## Tier 2 — real AI providers (unlock real voice conversations, no telephony)
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=

## Tier 3 — telephony
# SIP trunk credentials are NOT env vars (D6: config over env) — add/edit trunks
# from the console's Trunks page once Stage 4/5 land. Nothing to set here.

## Tier 4 — optional ops
# LOG_LEVEL=debug
# LOG_PRETTY=true
# AGENT_LOG_FILE=/tmp/callplane-agent.log

## Ship logs to Axiom (post-v1) — set both to enable; independent of LOG_PRETTY (both can be on).
# AXIOM_TOKEN=
# AXIOM_DATASET=callplane-logs

## Recordings storage backend (post-v1) — must match apps/api/.env's STORAGE_ADAPTER exactly.
# STORAGE_ADAPTER=azure-blob
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=callplane-recordings
