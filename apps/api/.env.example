## Tier 1 — browser demo (no external accounts required)
NODE_ENV=development
SERVICE_NAME=callplane-api
PORT=4300
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/callplane?schema=callplane
REDIS_URL=redis://localhost:6379
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
PROVIDER_STUB_MODE=true
SIP_STUB_MODE=true
RECORDING_MODE=stub
# Any non-empty string works locally — this only gates the API's own Bearer auth.
CALLPLANE_API_KEY=dev-local-only-change-me

## Tier 2 — real AI providers (unlock real voice conversations, no telephony)
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=

## Tier 3 — telephony
# SIP trunk credentials are NOT env vars (D6: config over env) — add/edit trunks
# from the console's Trunks page once Stage 4/5 land. Nothing to set here.

## Tier 4 — optional ops
# LOG_LEVEL=debug
# LOG_PRETTY=true
# AGENT_LOG_FILE=/tmp/callplane-agent.log
