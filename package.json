{
  "name": "callplane",
  "version": "0.0.1",
  "private": true,
  "description": "A production-grade AI voice agent control plane — three voice modes, multi-provider failover, SIP telephony, reliable webhooks, cost metering, and a self-service admin console.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "test": "turbo test && npm run test:scripts",
    "test:scripts": "node --test scripts/lib/*.test.mjs",
    "clean": "turbo clean",
    "setup": "node scripts/setup.mjs",
    "check-links": "node scripts/check-links.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.0",
    "eslint": "^9.19.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.2"
}
